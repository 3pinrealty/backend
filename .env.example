CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=
MONGO_URI=

# Comma-separated list of allowed origins (optional).
# If empty, CORS will allow all origins (not recommended for production).
# Example:
# CORS_ORIGIN=https://your-frontend.up.railway.app,https://yourdomain.com
CORS_ORIGIN=

# Optional rate limit tuning
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

NODE_ENV=production
